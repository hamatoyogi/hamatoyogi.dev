const filterOptions = [
  { label: 'Talks', value: 'talk' },
  { label: 'Podcasts', value: 'podcast' },
  { label: 'Interviews', value: 'interview' },
];
---

<BaseLayout
  title="Appearances | hamatoyogi.dev"
  description="Appearances, podcasts, interviews, and talks by Yoav Ganbar"
>
  <div class="mx-auto px-[var(--space-page-x)] py-16" style="max-width: var(--max-w-content)">
    <h1 class="font-syne text-5xl font-bold leading-snug text-ink dark:text-[#F0ECE4]">Appearances</h1>
    <p class="mt-2 font-mono text-sm text-muted dark:text-[#9A95A8]">
      {list.length} talks, podcasts, and interviews
    </p>

    <div class="mt-8">
      <FilterPills
        client:load
        options={filterOptions}
        targetAttr="data-category"
      />
    </div>

    <div class="mt-6 flex flex-col gap-3">
      {list.map((item) => (
        <AppearanceRow
          title={item.title}
          venue={item.where}
          date={item.when}
          type={item.type}
          link={item.link}
        />
      ))}
    </div>
  </div>
</BaseLayout>
