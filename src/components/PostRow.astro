---
export interface Props {
  title: string;
  description?: string;
  date: string;
  link: string;
  isExternal: boolean;
  category?: string;
}

const { title, description, date, link, isExternal, category } = Astro.props;
---

<a
  href={link}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
  data-filterable
  data-category={category || 'all'}
  class="group flex items-start justify-between gap-4 rounded-[var(--radius-md)] border border-border bg-surface px-4 py-4 transition-all hover:-translate-y-0.5 hover:shadow-md dark:border-[#2A2D3E] dark:bg-[#1A1D2E]"
>
  <div class="flex flex-col gap-1 min-w-0">
    <p class="font-jakarta text-base font-semibold text-ink leading-snug dark:text-[#F0ECE4]">
      {title}
    </p>
    {description && (
      <p class="font-jakarta text-sm text-muted line-clamp-2 dark:text-[#9A95A8]">{description}</p>
    )}
    <span class="font-mono text-xs text-muted dark:text-[#9A95A8]">{date}</span>
  </div>
  <div class="flex-shrink-0 pt-1 text-coral text-base leading-none">
    {isExternal ? '↗' : '→'}
  </div>
</a>
